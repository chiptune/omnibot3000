{
  "name": "omnibot3000",
  "x-display-name": "OMNIBOT 3000",
  "description": "your omniscient source of truth",
  "private": false,
  "version": "1.10.0",
  "type": "module",
  "author": {
    "name": "rez",
    "email": "rez@lol.pm",
    "url": "https://github.com/chiptune"
  },
  "homepage": "https://www.omnibot3000.com",
  "repository": {
    "url": "https://github.com/chiptune/omnibot3000",
    "type": "github"
  },
  "bin": {
    "omnibot": "./bin/omnibot.js"
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "start": "pnpm run-p start:dev start:api",
    "start:dev": "pnpm run dev",
    "start:api": "nodemon api/server.ts",
    "start:prod": "pnpm run build && pnpm run-p prod api",
    "dev": "vite",
    "prod": "vite preview --port 4173",
    "api": "node dist/api/server.js",
    "build": "pnpm run build:client && pnpm run build:api",
    "build:client": "tsc -b && vite build",
    "build:api": "tsc --project tsconfig.api.json",
    "lint": "eslint --fix .",
    "lint:css": "stylelint --fix 'src/**/*.css'",
    "lint:deps": "knip --dependencies",
    "prettify": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.2.1",
    "dotenv": "^17.4.2",
    "openai": "^6.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "classnames": "^2.5.1",
    "eslint": "^10.4.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "react-refresh": "^0.18.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14"
  }
}
